<odoo noupdate="1">

    <record id="ir_cron_l10n_pe_update_sbs_rates" model="ir.cron">
        <field name="name">Peru: actualizar T/C SBS diario</field>
        <field name="model_id" ref="base.model_res_company"/>
        <field name="state">code</field>
        <field name="code">model._cron_l10n_pe_update_sbs_rates()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">1</field>
        <field name="interval_type">days</field>
        <!-- 02:00 UTC ≈ 21:00 hora Lima del día anterior; SBS publica ~17:00 Lima -->
        <field name="nextcall" eval="(DateTime.now().replace(hour=2, minute=0, second=0) + relativedelta(days=1)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active" eval="True"/>
    </record>

</odoo>
