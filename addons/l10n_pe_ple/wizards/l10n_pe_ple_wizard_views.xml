<odoo>

    <record id="view_l10n_pe_ple_wizard_form" model="ir.ui.view">
        <field name="name">l10n.pe.ple.wizard.form</field>
        <field name="model">l10n.pe.ple.wizard</field>
        <field name="arch" type="xml">
            <form string="Generar PLE SUNAT">
                <group>
                    <field name="company_id" groups="base.group_multi_company"/>
                    <field name="period_yyyymm" placeholder="202604"/>
                    <field name="libro"/>
                </group>
                <group string="Resultado" invisible="not file_data">
                    <field name="file_name" readonly="1"/>
                    <field name="line_count" readonly="1"/>
                    <field name="file_data" filename="file_name" readonly="1"/>
                </group>
                <footer>
                    <button name="action_generate"
                            type="object"
                            string="Generar"
                            class="btn-primary"/>
                    <button special="cancel" string="Cerrar"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_l10n_pe_ple_wizard" model="ir.actions.act_window">
        <field name="name">Generar PLE (Perú)</field>
        <field name="res_model">l10n.pe.ple.wizard</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_l10n_pe_ple_wizard"
              name="PLE (Libros Electrónicos)"
              parent="account.menu_finance_reports"
              action="action_l10n_pe_ple_wizard"
              sequence="220"/>

</odoo>
