<odoo>

    <record id="view_l10n_pe_upload_supplier_xml_form" model="ir.ui.view">
        <field name="name">l10n.pe.upload.supplier.xml.form</field>
        <field name="model">l10n.pe.upload.supplier.xml</field>
        <field name="arch" type="xml">
            <form string="Subir XML UBL de proveedor">
                <group>
                    <field name="xml_file" filename="xml_filename"/>
                    <field name="xml_filename" invisible="1"/>
                    <field name="auto_create_partner"/>
                </group>
                <p class="text-muted">
                    Sube el archivo XML UBL 2.1 que el proveedor te envió.
                    Se creará un borrador de factura de compra con el RUC
                    del proveedor, número de documento, líneas y totales.
                    El XML se adjunta al move para trazabilidad.
                </p>
                <footer>
                    <button name="action_parse_and_create"
                            type="object"
                            string="Procesar y crear borrador"
                            class="btn-primary"/>
                    <button special="cancel" string="Cancelar" class="btn-secondary"/>
                </footer>
            </form>
        </field>
    </record>

    <record id="action_l10n_pe_upload_supplier_xml" model="ir.actions.act_window">
        <field name="name">Subir XML de proveedor (Perú)</field>
        <field name="res_model">l10n.pe.upload.supplier.xml</field>
        <field name="view_mode">form</field>
        <field name="target">new</field>
    </record>

    <menuitem id="menu_l10n_pe_upload_supplier_xml"
              name="Importar XML proveedor (PE)"
              parent="account.menu_finance_receivables"
              action="action_l10n_pe_upload_supplier_xml"
              sequence="50"/>

</odoo>
