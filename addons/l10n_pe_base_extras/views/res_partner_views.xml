<odoo>

    <record id="view_partner_form_l10n_pe_extras" model="ir.ui.view">
        <field name="name">res.partner.form.l10n.pe.extras</field>
        <field name="model">res.partner</field>
        <field name="inherit_id" ref="base.view_partner_form"/>
        <field name="arch" type="xml">
            <!--
                Botón "Consultar en SUNAT/RENIEC" justo al lado del VAT.
                Visible solo cuando hay vat + tipo de doc reconocido (RUC/DNI).
            -->
            <xpath expr="//field[@name='vat']" position="after">
                <button name="action_l10n_pe_query_apisnet"
                        type="object"
                        string="Consultar en SUNAT/RENIEC"
                        class="oe_link"
                        icon="fa-cloud-download"
                        invisible="not vat or not l10n_latam_identification_type_id"
                        help="Consulta apis.net.pe y autocompleta nombre y dirección."/>
            </xpath>
        </field>
    </record>

</odoo>
