<odoo>

    <record id="view_company_form_l10n_pe_extras" model="ir.ui.view">
        <field name="name">res.company.form.l10n.pe.extras</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="base.view_company_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='vat']" position="after">
                <field name="l10n_pe_regimen_tributario"/>
                <field name="l10n_pe_apisnet_token" password="True"/>
            </xpath>
        </field>
    </record>

</odoo>
