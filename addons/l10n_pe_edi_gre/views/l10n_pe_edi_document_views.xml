<odoo>

    <record id="view_l10n_pe_edi_document_form_gre" model="ir.ui.view">
        <field name="name">l10n.pe.edi.document.form.gre</field>
        <field name="model">l10n.pe.edi.document</field>
        <field name="inherit_id" ref="l10n_pe_edi.view_l10n_pe_edi_document_form"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='digest_value']" position="after">
                <group string="GRE 2.0 (REST)" invisible="not gre_ticket">
                    <field name="gre_sent_at"/>
                    <field name="gre_ticket"/>
                    <field name="gre_ind_estado"/>
                    <field name="gre_last_status_check_at"/>
                    <field name="gre_cdr" filename="gre_cdr_filename"/>
                    <field name="gre_cdr_filename" invisible="1"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <button name="action_l10n_pe_gre_check_status"
                        type="object"
                        string="Consultar estado GRE"
                        class="oe_highlight"
                        invisible="not gre_ticket or gre_ind_estado in ('05', '11')"/>
            </xpath>
        </field>
    </record>

</odoo>
