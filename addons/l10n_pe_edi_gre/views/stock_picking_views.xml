<odoo>

    <record id="view_stock_picking_form_l10n_pe_gre" model="ir.ui.view">
        <field name="name">stock.picking.form.l10n.pe.gre</field>
        <field name="model">stock.picking</field>
        <field name="inherit_id" ref="stock.view_picking_form"/>
        <field name="arch" type="xml">
            <xpath expr="//notebook" position="inside">
                <page string="Guía de Remisión (PE)" name="l10n_pe_gre">
                    <group>
                        <group string="Traslado">
                            <field name="l10n_pe_gre_motivo_traslado"/>
                            <field name="l10n_pe_gre_motivo_descripcion"/>
                            <field name="l10n_pe_gre_gross_weight"/>
                            <field name="l10n_pe_gre_total_packages"/>
                        </group>
                        <group string="Transporte">
                            <field name="l10n_pe_gre_transport_mode"/>
                            <field name="l10n_pe_gre_carrier_id"
                                   invisible="l10n_pe_gre_transport_mode != '01'"/>
                            <field name="l10n_pe_gre_license_plate"/>
                            <field name="l10n_pe_gre_driver_doc_type"/>
                            <field name="l10n_pe_gre_driver_doc_number"/>
                        </group>
                    </group>
                    <group>
                        <group string="Origen">
                            <field name="l10n_pe_gre_origin_ubigeo"/>
                            <field name="l10n_pe_gre_origin_street"/>
                        </group>
                        <group string="Destino">
                            <field name="l10n_pe_gre_destination_ubigeo"/>
                            <field name="l10n_pe_gre_destination_street"/>
                        </group>
                    </group>
                    <group string="Documento EDI"
                           invisible="not l10n_pe_gre_edi_document_id">
                        <field name="l10n_pe_gre_edi_document_id" readonly="1"/>
                    </group>
                    <button name="action_l10n_pe_gre_generate"
                            type="object"
                            string="Generar GRE Remitente"
                            class="btn-primary"
                            invisible="state != 'done' or l10n_pe_gre_edi_document_id"/>
                </page>
            </xpath>
        </field>
    </record>

</odoo>
