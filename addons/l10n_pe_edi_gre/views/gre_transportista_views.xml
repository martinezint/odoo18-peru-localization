<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_gre_transportista_tree" model="ir.ui.view">
    <field name="name">l10n.pe.gre.transportista.tree</field>
    <field name="model">l10n.pe.gre.transportista</field>
    <field name="arch" type="xml">
      <list decoration-info="state == 'sent'" decoration-success="state == 'accepted'" decoration-danger="state == 'error'">
        <field name="name"/>
        <field name="issue_date"/>
        <field name="remitente_partner_id"/>
        <field name="destinatario_partner_id"/>
        <field name="related_remitente_serie_number"/>
        <field name="state"/>
      </list>
    </field>
  </record>

  <record id="view_gre_transportista_form" model="ir.ui.view">
    <field name="name">l10n.pe.gre.transportista.form</field>
    <field name="model">l10n.pe.gre.transportista</field>
    <field name="arch" type="xml">
      <form>
        <header>
          <button name="action_generate_xml" type="object" string="Generar XML (sin enviar)" class="btn-secondary" invisible="state != 'draft'"/>
          <button name="action_generate_and_send" type="object" string="Generar y enviar a SUNAT" class="btn-primary" invisible="state not in ('draft', 'generated', 'error')"/>
          <field name="state" widget="statusbar"/>
        </header>
        <sheet>
          <div class="oe_title">
            <label for="name"/>
            <h1><field name="name" placeholder="V001-1"/></h1>
          </div>
          <group>
            <group string="Documento">
              <field name="issue_date"/>
              <field name="issue_time"/>
              <field name="company_id" groups="base.group_multi_company"/>
              <field name="related_remitente_serie_number"/>
            </group>
            <group string="Partes">
              <field name="remitente_partner_id" options="{'no_create_edit': True}"/>
              <field name="destinatario_partner_id" options="{'no_create_edit': True}"/>
            </group>
          </group>
          <group>
            <group string="Vehículo + conductor">
              <field name="license_plate"/>
              <field name="driver_doc_type"/>
              <field name="driver_doc_number"/>
              <field name="transit_start_date"/>
            </group>
            <group string="Origen / destino">
              <field name="origin_ubigeo"/>
              <field name="origin_street"/>
              <field name="destination_ubigeo"/>
              <field name="destination_street"/>
            </group>
          </group>
          <group string="Carga">
            <field name="gross_weight"/>
            <field name="total_packages"/>
            <field name="split_consignment"/>
          </group>
          <notebook>
            <page string="Ítems">
              <field name="line_ids">
                <list editable="bottom">
                  <field name="sequence" widget="handle"/>
                  <field name="description"/>
                  <field name="quantity"/>
                  <field name="unit_code"/>
                  <field name="item_code"/>
                </list>
              </field>
            </page>
            <page string="EDI">
              <group>
                <field name="gre_ticket" readonly="1"/>
                <field name="xml_signed" filename="name" readonly="1"/>
                <field name="error_message" readonly="1" invisible="not error_message"/>
              </group>
            </page>
          </notebook>
        </sheet>
        <chatter/>
      </form>
    </field>
  </record>

  <record id="action_gre_transportista" model="ir.actions.act_window">
    <field name="name">GRE Transportista</field>
    <field name="res_model">l10n.pe.gre.transportista</field>
    <field name="view_mode">list,form</field>
  </record>

  <menuitem
      id="menu_gre_transportista"
      name="GRE Transportista (cód 31)"
      parent="stock.menu_stock_warehouse_mgmt"
      action="action_gre_transportista"
      sequence="60"/>
</odoo>
