<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_account_move_l10n_pe_double_entry_form" model="ir.ui.view">
    <field name="name">account.move.form.l10n_pe_double_entry</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <!-- Botón en header solo si tiene clase 6 y aún no se generó -->
      <xpath expr="//header" position="inside">
        <button name="action_l10n_pe_generate_double_entry"
                type="object"
                string="Generar doble apunte 6↔9"
                class="btn-secondary"
                invisible="not l10n_pe_needs_double_entry"
                groups="account.group_account_user"/>
      </xpath>
      <!-- Tab nuevo con los campos -->
      <xpath expr="//notebook" position="inside">
        <page string="Doble apunte PE (6↔9)" invisible="not l10n_pe_needs_double_entry and not l10n_pe_double_entry_move_id and not l10n_pe_double_entry_origin_id">
          <group>
            <group>
              <field name="l10n_pe_destination_type"/>
              <field name="l10n_pe_destination_account_id"
                     invisible="l10n_pe_destination_type != 'manual'"
                     required="l10n_pe_destination_type == 'manual'"/>
              <field name="l10n_pe_needs_double_entry" readonly="1"/>
            </group>
            <group>
              <field name="l10n_pe_double_entry_move_id" readonly="1"/>
              <field name="l10n_pe_double_entry_origin_id" readonly="1"/>
            </group>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>
