<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_double_entry_batch_wizard_form" model="ir.ui.view">
    <field name="name">l10n.pe.double.entry.batch.wizard.form</field>
    <field name="model">l10n.pe.double.entry.batch.wizard</field>
    <field name="arch" type="xml">
      <form string="Generar dobles apuntes 6↔9 pendientes">
        <group>
          <group>
            <field name="company_id" groups="base.group_multi_company"/>
            <field name="date_from"/>
            <field name="date_to"/>
          </group>
          <group invisible="not processed_count" string="Resultado">
            <field name="processed_count" readonly="1"/>
            <field name="generated_count" readonly="1"/>
            <field name="skipped_count" readonly="1"/>
          </group>
        </group>
        <group invisible="not error_log" string="Errores">
          <field name="error_log" readonly="1" nolabel="1" widget="text"/>
        </group>
        <footer>
          <button name="action_run" type="object" string="Ejecutar" class="btn-primary"/>
          <button special="cancel" string="Cerrar" class="btn-secondary"/>
        </footer>
      </form>
    </field>
  </record>

  <record id="action_double_entry_batch_wizard" model="ir.actions.act_window">
    <field name="name">Doble apunte PE — Regularizar pendientes</field>
    <field name="res_model">l10n.pe.double.entry.batch.wizard</field>
    <field name="view_mode">form</field>
    <field name="target">new</field>
  </record>

  <menuitem
      id="menu_double_entry_batch_wizard"
      name="Doble apunte 6↔9 (Perú)"
      parent="account.menu_finance_entries"
      action="action_double_entry_batch_wizard"
      sequence="55"/>
</odoo>
