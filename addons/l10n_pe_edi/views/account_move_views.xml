<odoo>

    <record id="view_account_move_form_l10n_pe_edi" model="ir.ui.view">
        <field name="name">account.move.form.l10n.pe.edi</field>
        <field name="model">account.move</field>
        <field name="inherit_id" ref="account.view_move_form"/>
        <field name="arch" type="xml">
            <xpath expr="//header" position="inside">
                <button name="action_l10n_pe_edi_generate"
                        type="object"
                        string="Generar EDI SUNAT"
                        class="oe_highlight"
                        invisible="state != 'posted' or move_type not in ('out_invoice', 'out_refund')
                                   or l10n_pe_edi_state in ('signed', 'sent', 'accepted')"/>
                <field name="l10n_pe_edi_state" widget="statusbar"
                       statusbar_visible="draft,signed,sent,accepted"
                       invisible="not l10n_pe_edi_document_id"/>
            </xpath>
            <xpath expr="//page[@id='other_tab']" position="inside">
                <group string="EDI SUNAT" invisible="not l10n_pe_edi_document_id">
                    <field name="l10n_pe_edi_document_id" readonly="1"/>
                    <field name="l10n_pe_edi_state" readonly="1"/>
                </group>
            </xpath>
        </field>
    </record>

</odoo>
