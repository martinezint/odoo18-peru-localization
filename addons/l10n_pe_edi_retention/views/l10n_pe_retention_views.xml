<odoo>

    <record id="view_l10n_pe_retention_tree" model="ir.ui.view">
        <field name="name">l10n.pe.retention.list</field>
        <field name="model">l10n.pe.retention</field>
        <field name="arch" type="xml">
            <list string="Comprobantes de Retención">
                <field name="name"/>
                <field name="issue_date"/>
                <field name="partner_id"/>
                <field name="regime_code"/>
                <field name="total_retention_amount" sum="Total retenido"/>
                <field name="currency_id" optional="hide"/>
                <field name="state" widget="badge"
                       decoration-info="state == 'draft'"
                       decoration-success="state == 'posted'"
                       decoration-danger="state == 'cancel'"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_pe_retention_form" model="ir.ui.view">
        <field name="name">l10n.pe.retention.form</field>
        <field name="model">l10n.pe.retention</field>
        <field name="arch" type="xml">
            <form string="Comprobante de Retención">
                <header>
                    <field name="state" widget="statusbar"/>
                </header>
                <sheet>
                    <group>
                        <group>
                            <field name="name"/>
                            <field name="issue_date"/>
                            <field name="partner_id"/>
                            <field name="currency_id"/>
                        </group>
                        <group>
                            <field name="regime_code"/>
                            <field name="regime_percent"/>
                            <field name="total_retention_amount" readonly="1"/>
                            <field name="total_paid" readonly="1"/>
                            <field name="company_id" groups="base.group_multi_company"/>
                            <field name="edi_document_id" readonly="1"
                                   invisible="not edi_document_id"/>
                        </group>
                    </group>
                    <field name="note_amount_in_words"/>
                    <notebook>
                        <page string="Documentos retenidos">
                            <field name="line_ids">
                                <list editable="bottom">
                                    <field name="sequence" widget="handle"/>
                                    <field name="doc_type_code"/>
                                    <field name="doc_serie_number"/>
                                    <field name="doc_issue_date"/>
                                    <field name="doc_total_amount"/>
                                    <field name="paid_amount"/>
                                    <field name="paid_date"/>
                                    <field name="retention_amount"/>
                                    <field name="retention_date"/>
                                    <field name="net_total_cashed" readonly="1"/>
                                    <field name="currency_id" column_invisible="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_l10n_pe_retention" model="ir.actions.act_window">
        <field name="name">Comprobantes de Retención</field>
        <field name="res_model">l10n.pe.retention</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_l10n_pe_retention"
              name="Retenciones (PE)"
              parent="account.menu_finance_receivables"
              action="action_l10n_pe_retention"
              sequence="80"/>

</odoo>
