<odoo>

    <record id="view_product_template_form_l10n_pe_detraccion" model="ir.ui.view">
        <field name="name">product.template.form.l10n.pe.detraccion</field>
        <field name="model">product.template</field>
        <field name="inherit_id" ref="account.product_template_form_view"/>
        <field name="arch" type="xml">
            <xpath expr="//group[@name='accounting']" position="inside">
                <field name="l10n_pe_detraccion_code_id"
                       options="{'no_create': True}"/>
            </xpath>
        </field>
    </record>

</odoo>
