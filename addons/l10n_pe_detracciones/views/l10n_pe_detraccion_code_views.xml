<odoo>

    <record id="view_l10n_pe_detraccion_code_tree" model="ir.ui.view">
        <field name="name">l10n.pe.detraccion.code.list</field>
        <field name="model">l10n.pe.detraccion.code</field>
        <field name="arch" type="xml">
            <list string="Códigos de Detracción SUNAT" editable="bottom">
                <field name="code"/>
                <field name="name"/>
                <field name="anexo"/>
                <field name="percentage" widget="percentage"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <record id="view_l10n_pe_detraccion_code_form" model="ir.ui.view">
        <field name="name">l10n.pe.detraccion.code.form</field>
        <field name="model">l10n.pe.detraccion.code</field>
        <field name="arch" type="xml">
            <form string="Código de Detracción">
                <sheet>
                    <group>
                        <field name="code"/>
                        <field name="name"/>
                        <field name="anexo"/>
                        <field name="percentage"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="view_l10n_pe_detraccion_code_search" model="ir.ui.view">
        <field name="name">l10n.pe.detraccion.code.search</field>
        <field name="model">l10n.pe.detraccion.code</field>
        <field name="arch" type="xml">
            <search>
                <field name="code"/>
                <field name="name"/>
                <filter name="filter_anexo_2" string="Anexo 2 (Bienes)" domain="[('anexo', '=', '2')]"/>
                <filter name="filter_anexo_3" string="Anexo 3 (Servicios)" domain="[('anexo', '=', '3')]"/>
                <separator/>
                <filter name="filter_inactive" string="Archivados" domain="[('active', '=', False)]"/>
                <group expand="0" string="Agrupar por">
                    <filter name="group_anexo" string="Anexo" context="{'group_by': 'anexo'}"/>
                </group>
            </search>
        </field>
    </record>

    <record id="action_l10n_pe_detraccion_code" model="ir.actions.act_window">
        <field name="name">Códigos de Detracción</field>
        <field name="res_model">l10n.pe.detraccion.code</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_l10n_pe_detraccion_code"
              name="Códigos de Detracción"
              parent="account.account_account_menu"
              action="action_l10n_pe_detraccion_code"
              sequence="100"/>

</odoo>
