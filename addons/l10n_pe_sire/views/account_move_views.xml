<?xml version="1.0" encoding="utf-8"?>
<odoo>
  <record id="view_account_move_l10n_pe_sire_form" model="ir.ui.view">
    <field name="name">account.move.form.l10n_pe_sire</field>
    <field name="model">account.move</field>
    <field name="inherit_id" ref="account.view_move_form"/>
    <field name="arch" type="xml">
      <xpath expr="//notebook" position="inside">
        <page string="SIRE" invisible="move_type not in ('in_invoice', 'in_refund')">
          <group>
            <field name="l10n_pe_sire_match_status" readonly="1"/>
            <field name="l10n_pe_sire_match_period" readonly="1"/>
            <field name="l10n_pe_sire_match_diff" readonly="1" invisible="not l10n_pe_sire_match_diff"/>
          </group>
        </page>
      </xpath>
    </field>
  </record>
</odoo>
