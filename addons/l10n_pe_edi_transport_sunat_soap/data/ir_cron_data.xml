<odoo noupdate="1">

    <record id="ir_cron_l10n_pe_poll_summary_tickets" model="ir.cron">
        <field name="name">Peru SUNAT: poll tickets RC async (sendSummary)</field>
        <field name="model_id" ref="l10n_pe_edi.model_l10n_pe_edi_document"/>
        <field name="state">code</field>
        <field name="code">model._cron_poll_summary_tickets()</field>
        <field name="user_id" ref="base.user_root"/>
        <field name="interval_number">10</field>
        <field name="interval_type">minutes</field>
        <field name="nextcall" eval="(DateTime.now() + relativedelta(minutes=10)).strftime('%Y-%m-%d %H:%M:%S')"/>
        <field name="active" eval="True"/>
    </record>

</odoo>
