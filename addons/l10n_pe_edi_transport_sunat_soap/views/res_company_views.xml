<odoo>

    <record id="view_company_form_l10n_pe_edi_transport" model="ir.ui.view">
        <field name="name">res.company.form.l10n.pe.edi.transport</field>
        <field name="model">res.company</field>
        <field name="inherit_id" ref="l10n_pe_edi.view_company_form_l10n_pe_edi"/>
        <field name="arch" type="xml">
            <xpath expr="//field[@name='l10n_pe_edi_cert_password']" position="after">
                <field name="l10n_pe_edi_sol_user"/>
                <field name="l10n_pe_edi_sol_password" password="True"/>
            </xpath>
        </field>
    </record>

</odoo>
