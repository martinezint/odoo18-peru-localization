<odoo>

    <record id="view_l10n_pe_edi_document_form_transport" model="ir.ui.view">
        <field name="name">l10n.pe.edi.document.form.transport</field>
        <field name="model">l10n.pe.edi.document</field>
        <field name="inherit_id" ref="l10n_pe_edi.view_l10n_pe_edi_document_form"/>
        <field name="arch" type="xml">
            <!--
                Anclamos al campo digest_value (estable) en vez del group[@string]
                porque Odoo 18 prohíbe selectores por @string en inheritance.
            -->
            <xpath expr="//field[@name='digest_value']" position="after">
                <group string="Respuesta SUNAT (CDR)"
                       invisible="not sunat_response_code">
                    <field name="sunat_sent_at"/>
                    <field name="sunat_response_code"/>
                    <field name="sunat_response_description"/>
                    <field name="sunat_cdr" filename="sunat_cdr_filename"/>
                    <field name="sunat_cdr_filename" invisible="1"/>
                </group>
                <group string="Envío asíncrono (RC / RA)"
                       invisible="not sunat_summary_ticket">
                    <field name="sunat_summary_ticket"/>
                    <field name="sunat_summary_status_code"/>
                    <field name="sunat_summary_last_check_at"/>
                </group>
            </xpath>
            <xpath expr="//field[@name='state']" position="after">
                <button name="action_l10n_pe_send_summary"
                        type="object"
                        string="Enviar como RC (async)"
                        class="oe_highlight"
                        invisible="not xml_signed or state == 'accepted' or sunat_summary_ticket"/>
                <button name="action_l10n_pe_check_summary_status"
                        type="object"
                        string="Consultar estado RC"
                        class="oe_highlight"
                        invisible="not sunat_summary_ticket or sunat_summary_status_code == '0'"/>
            </xpath>
        </field>
    </record>

</odoo>
